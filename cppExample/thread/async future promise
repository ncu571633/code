std::async: returns a std::future
fut.get() blocks execution and waits for the asynchronous thread to finish if it has not completed already.

#include <iostream>       // std::cout
#include <future>         // std::async, std::future

// a non-optimized way of checking for prime numbers:
bool is_prime (int x) {
  for (int i=2; i<x; ++i) if (x%i==0) return false;
  return true;
}

int main ()
{
  // call function asynchronously:
  
  // runs is_prime on a separate thread immediately. fut.get() blocks only if the thread is still running when you call it.
  // // Force background thread execution
  // std::future<bool> fut = std::async(std::launch::async, is_prime, 444444443);
  
  // does not create a thread. Instead, it waits until you call fut.get() to execute is_prime sequentially on the main thread
  // Force sequential, lazy evaluation
  // std::future<bool> fut = std::async(std::launch::deferred, is_prime, 444444443);
  
  // whether async or deferred is determined at the run time based on resource available 
  std::future<bool> fut = std::async (is_prime,444444443); 

  bool x = fut.get();     // retrieve return value

  std::cout << "\n444444443 " << (x?"is":"is not") << " prime.\n";

  return 0;
}


